{
  "compilerOptions": {
    "lib": ["ES2022"],
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "removeComments": true,
    "declaration": true,
    "isolatedModules": true,
    "types": ["node"]
  },
  "include": ["index.ts", "lib/**/*.ts"],
  "exclude": ["**/*.test.ts"]
}
